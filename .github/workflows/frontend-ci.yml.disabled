name: Frontend CI

on:
  push:
    branches: [main, develop, 'feature/**']
  pull_request:
    branches: [main, develop]

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Use Node.js 22
        uses: actions/setup-node@v4
        with:
          node-version: '22'
          cache: ${{ hashFiles('frontend/package-lock.json') != '' && 'npm' || '' }}
          cache-dependency-path: ${{ hashFiles('frontend/package-lock.json') != '' && 'frontend/package-lock.json' || '' }}

      - name: Install dependencies
        working-directory: ./frontend
        run: npm install

      - name: Build
        working-directory: ./frontend
        env:
          CI: false
          REACT_APP_API_URL: https://tmsbackend-api-f6gwc7ejfphmg5f3.southeastasia-01.azurewebsites.net
          REACT_APP_WS_URL: wss://tmsbackend-api-f6gwc7ejfphmg5f3.southeastasia-01.azurewebsites.net
        run: npm run build
